Options -MultiViews
RewriteEngine On

# specific rule for user profile (if we want /user/username)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^user/([a-zA-Z0-9_-]+)$ user.php?username=$1 [L,QSA]

# specific rule for game/id (if we want /game/123)
# checking if game.php exists first not strictly necessary if we know it does, but good practice
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^game/([0-9]+)$ game.php?id=$1 [L,QSA]

# Redirect index.php to root
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s(.*)/index\.php [NC]
RewriteRule ^ %1/ [R=301,L,QSA]

# Redirect other .php files to clean URL (external redirect) - only for GET requests
RewriteCond %{REQUEST_METHOD} !POST
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteRule ^ %1 [R=301,L,QSA]

# Handle clean URLs (internal rewrite)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^([^/]+)/?$ $1.php [L]
